{
  "name": "design-checker",
  "version": "0.1.0",
  "description": "Analyze a public website and emit Codex-friendly frontend design artifacts.",
  "type": "module",
  "bin": {
    "design-checker": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "playwright": "^1.54.0",
    "postcss": "^8.5.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
