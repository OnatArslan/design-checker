{
  "name": "design-checker",
  "version": "0.1.0",
  "description": "Analyze a public website and emit Codex-friendly frontend design artifacts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "design-checker": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "design-analysis",
    "design-system",
    "frontend",
    "playwright",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OnatArslan/design-checker.git"
  },
  "bugs": {
    "url": "https://github.com/OnatArslan/design-checker/issues"
  },
  "homepage": "https://github.com/OnatArslan/design-checker#readme",
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "playwright": "^1.54.0",
    "postcss": "^8.5.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
